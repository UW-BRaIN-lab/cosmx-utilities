# CosMx analysis pipeline configuration
# Copy this file to .env and fill in your values:
#   cp pipeline/.env.example pipeline/.env

# --- Source AWS S3: where the original CosMx flat files + Seurat .RDS live ---
SOURCE_S3_BUCKET=keene-cosmx-data
SOURCE_S3_PREFIX=CosMx-GBM/Wenyu-cohort

# AWS source credentials for migrate_s3_to_kopah.py. Set one of:
#   (1) AWS_SOURCE_ACCESS_KEY_ID + AWS_SOURCE_SECRET_ACCESS_KEY (explicit), or
#   (2) AWS_SOURCE_PROFILE (named profile in ~/.aws/credentials).
# If both are empty, boto3 falls back to its default chain (~/.aws/credentials,
# env vars, instance profile). Explicit is recommended on klone where
# AWS_ACCESS_KEY_ID is set to Kopah keys by the kopah_brain shell helper.
AWS_SOURCE_ACCESS_KEY_ID=
AWS_SOURCE_SECRET_ACCESS_KEY=
AWS_SOURCE_PROFILE=

# --- UW Kopah: S3-compatible working storage for the pipeline ---
# Credentials are pre-provisioned at ~/kopah_<groupname> on klone.
KOPAH_ENDPOINT_URL=https://s3.kopah.uw.edu
KOPAH_BUCKET=brainlabkg
KOPAH_PREFIX=cosmx-gbm
KOPAH_ACCESS_KEY_ID=
KOPAH_SECRET_ACCESS_KEY=

# --- Hyak Slurm ---
SLURM_ACCOUNT=glioblastoma
SLURM_PARTITION_CPU=compute
SLURM_PARTITION_GPU=gpu-l40s

# --- Apptainer container paths on Hyak (built later; see pipeline/containers/) ---
APPTAINER_RSC=
APPTAINER_INSITUTYPE=
