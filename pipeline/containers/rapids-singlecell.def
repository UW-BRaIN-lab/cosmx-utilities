Bootstrap: docker
From: nvidia/cuda:12.4.1-cudnn-devel-ubuntu22.04

# NOTE: -devel-, not -runtime-. CuPy JIT-compiles kernels at runtime via
# NVRTC, which needs the CUDA toolkit *headers* (cuda_runtime.h etc.). The
# -runtime- image omits headers, and cupy 14+ no longer bundles them in its
# wheel, so GPU kernel compilation fails with "Failed to find CUDA headers".
# The -devel- image ships headers at /usr/local/cuda/include (where the
# CUDA_PATH in %environment points). Costs ~2-3GB more SIF; fine on scrubbed.
#
# Apptainer runtime for the CosMx GBM analysis pipeline on Hyak.
#
# Used by every stage that runs Python, both CPU (e.g. stage 1
# flatfiles_to_anndata.py on the `compute` partition) and GPU
# (e.g. stage 3 rapids-singlecell + Harmony on `gpu-l40s`).
#
# On 2x L40S (no NVLink, ~46GB VRAM each) we use dask-cuda's
# LocalCUDACluster to spread work across both GPUs. rapids-singlecell
# drives the GPU primitives; ScaleSC's single-GPU chunking is
# unnecessary at this scale (see containers/README.md for rationale).
#
# Build from the REPO ROOT — the %files lock path below is resolved relative
# to the build's working directory. On a klone login node (Apptainer +
# fakeroot), with cache/tmp on /gscratch (home is only 10GB):
#     cd ~/cosmx-utilities
#     export APPTAINER_CACHEDIR=/gscratch/scrubbed/$USER/apptainer-cache
#     export APPTAINER_TMPDIR=/gscratch/scrubbed/$USER/apptainer-tmp
#     apptainer build --fakeroot \
#         /gscratch/scrubbed/$USER/containers/rapids-singlecell.sif \
#         pipeline/containers/rapids-singlecell.def
#
# See pipeline/containers/README.md for the full build + install flow.

%files
    # Relative to the build CWD (the repo root), hence the build-from-root note.
    pipeline/containers/rapids-singlecell.lock /opt/rapids-singlecell.lock

%post -c /bin/bash
    set -euxo pipefail

    export DEBIAN_FRONTEND=noninteractive

    apt-get update
    apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        git \
        libgl1-mesa-glx \
        libhdf5-dev \
        libsm6 \
        libxrender1 \
        python3.10 \
        python3.10-dev \
        python3.10-venv \
        python3-pip
    rm -rf /var/lib/apt/lists/*

    update-alternatives --install /usr/bin/python  python  /usr/bin/python3.10 1
    update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.10 1

    # uv is the installer/resolver (not a runtime dep); pip just bootstraps it.
    python3 -m pip install uv

    # Create the venv with the system Python 3.10, seeding pip into it so any
    # tool that shells out to `python -m pip` inside the container still works.
    uv venv --python /usr/bin/python3.10 --seed /opt/venv

    # Reproducible install: sync the EXACT locked version set captured from the
    # 2026-05-27 validated build (see rapids-singlecell.lock). uv pip sync makes
    # the env match the lock precisely — no resolution, so no drift (the cupy
    # 13->14 jump that broke an earlier build can't recur).
    #
    # --extra-index-url + --index-strategy unsafe-best-match: the RAPIDS wheels
    # (cudf/cuml/rmm/cupy etc.) live across PyPI and pypi.nvidia.com; uv's
    # default first-index strategy stops at the first index and would miss them.
    VIRTUAL_ENV=/opt/venv uv pip sync \
        --extra-index-url https://pypi.nvidia.com \
        --index-strategy unsafe-best-match \
        /opt/rapids-singlecell.lock

    # Build-time import check: actually load the CPU-side packages, but only
    # verify the GPU-side packages are pip-installed without importing them.
    # Importing rapids_singlecell or dask_cuda triggers RMM/CUDA init, which
    # fails on the Klone login node (no GPU driver). The smoke test exercises
    # the real GPU imports inside a gpu-l40s allocation.
    /opt/venv/bin/python -c "
import scanpy, anndata
import importlib.util
for mod in ['rapids_singlecell', 'dask_cuda', 'cupy', 'rmm']:
    assert importlib.util.find_spec(mod) is not None, f'{mod} not installed'
print('imports ok')
"

%environment
    export PATH=/opt/venv/bin:$PATH
    export PYTHONNOUSERSITE=1
    export NVIDIA_VISIBLE_DEVICES=all
    export NVIDIA_DRIVER_CAPABILITIES=compute,utility
    # CuPy otherwise auto-detects the CUDA root from the driver version, which
    # fails ("Failed to auto-detect CUDA root directory") on Hyak's gpu-l40s
    # nodes because their driver (580.x / CUDA 13.0) is newer than cupy knows
    # about. Pin the root to the -devel- image's 12.4 toolkit, whose headers
    # at /usr/local/cuda/include are what NVRTC needs for JIT compilation.
    export CUDA_PATH=/usr/local/cuda

%runscript
    exec "$@"

%labels
    org.opencontainers.image.source https://github.com/keene-lab/cosmx-utilities
    org.opencontainers.image.description CosMx GBM pipeline runtime — scanpy, rapids-singlecell, dask-cuda, Harmony
    pipeline.stage rapids-singlecell
