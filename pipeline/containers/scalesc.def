Bootstrap: docker
From: nvidia/cuda:12.4.1-cudnn-runtime-ubuntu22.04

# Apptainer runtime for the CosMx GBM analysis pipeline on Hyak.
#
# Used by every stage that runs Python, both CPU (e.g. stage 1
# flatfiles_to_anndata.py on the `compute` partition) and GPU
# (e.g. stage 3 ScaleSC/Harmony on `gpu-l40s`).
#
# Build (klone login node has Apptainer + fakeroot):
#     apptainer build --fakeroot scalesc.sif pipeline/containers/scalesc.def
#
# See pipeline/containers/README.md for the full build + install flow.

%post -c /bin/bash
    set -euxo pipefail

    export DEBIAN_FRONTEND=noninteractive

    apt-get update
    apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        git \
        libgl1-mesa-glx \
        libhdf5-dev \
        libsm6 \
        libxrender1 \
        python3.10 \
        python3.10-dev \
        python3.10-venv \
        python3-pip
    rm -rf /var/lib/apt/lists/*

    update-alternatives --install /usr/bin/python  python  /usr/bin/python3.10 1
    update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.10 1

    python3.10 -m venv /opt/venv
    /opt/venv/bin/pip install --upgrade pip wheel setuptools

    # Core single-cell + IO stack. Stage 1 (flatfiles_to_anndata.py) needs
    # pandas, anndata, boto3, python-dotenv; scanpy pulls most of the rest.
    /opt/venv/bin/pip install \
        "anndata>=0.10" \
        "boto3>=1.34" \
        "h5py>=3.10" \
        "numpy>=1.24,<2.0" \
        "pandas>=2.0" \
        "python-dotenv>=1.0" \
        "scanpy>=1.10" \
        "scikit-learn>=1.3" \
        "tqdm>=4.66"

    # GPU stack. rapids-singlecell brings cudf-cu12, rmm-cu12, cuml-cu12,
    # and cupy-cuda12x via the [rapids12] extra. Pulled from NVIDIA's PyPI
    # index for the *-cu12 wheels.
    /opt/venv/bin/pip install \
        --extra-index-url=https://pypi.nvidia.com \
        "rapids-singlecell[rapids12]>=0.10"

    # Harmony: GPU path is rsc.tl.harmony_integrate from rapids-singlecell.
    # harmonypy is a CPU fallback for debugging / small subsets.
    /opt/venv/bin/pip install "harmonypy>=0.0.9"

    # ScaleSC has no PyPI release; pin to a commit once a working revision
    # is identified. See pipeline/containers/README.md for upgrade notes.
    /opt/venv/bin/pip install \
        "git+https://github.com/interactivereport/ScaleSC.git@main"

    /opt/venv/bin/python -c "import scanpy, anndata, rapids_singlecell, scalesc; print('imports ok')"

%environment
    export PATH=/opt/venv/bin:$PATH
    export PYTHONNOUSERSITE=1
    export NVIDIA_VISIBLE_DEVICES=all
    export NVIDIA_DRIVER_CAPABILITIES=compute,utility

%runscript
    exec "$@"

%labels
    org.opencontainers.image.source https://github.com/keene-lab/cosmx-utilities
    org.opencontainers.image.description CosMx GBM pipeline runtime — scanpy, rapids-singlecell, ScaleSC, Harmony
    pipeline.stage scalesc
